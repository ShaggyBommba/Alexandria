# App configuration
ALEXANDRIA_APP__APP_ENV=development
ALEXANDRIA_APP__APP_NAME=alexandria
ALEXANDRIA_APP__APP_VERSION=0.1.0
ALEXANDRIA_APP__DEBUG=false
ALEXANDRIA_APP__API_HOST=localhost
ALEXANDRIA_APP__API_PORT=8002
ALEXANDRIA_APP__MCP_HOST=localhost
ALEXANDRIA_APP__MCP_PORT=9002
ALEXANDRIA_APP__WORKER_POLL_INTERVAL=3


# outbox configuration
ALEXANDRIA_OUTBOX__MAX_PENDING=10000
ALEXANDRIA_OUTBOX__BATCH_SIZE=25
ALEXANDRIA_OUTBOX__MAX_ATTEMPTS=3
ALEXANDRIA_OUTBOX__VISIBILITY_TIMEOUT_SECONDS=300

# Agent configuration
ALEXANDRIA_AGENTS__LANGCHAIN__MODEL=<REDACTED>
ALEXANDRIA_AGENTS__LANGCHAIN__TEMPERATURE=0.0
ALEXANDRIA_AGENTS__LANGCHAIN__TIMEOUT_SECONDS=30
ALEXANDRIA_AGENTS__LANGCHAIN__API_KEY=<REDACTED>
ALEXANDRIA_AGENTS__LANGCHAIN__API_BASE_URL=<REDACTED>
ALEXANDRIA_AGENTS__MATCH__PROMPT=match
ALEXANDRIA_AGENTS__MATCH__MAX_CANDIDATES=50
ALEXANDRIA_AGENTS__SEARCH__PROMPT=search
ALEXANDRIA_AGENTS__SEARCH__MAX_CANDIDATES=50
ALEXANDRIA_AGENTS__SEARCH__MAX_RESULTS=20
ALEXANDRIA_AGENTS__SPLIT__MAKE_PROMPT=split_make
ALEXANDRIA_AGENTS__SPLIT__PICK_PROMPT=split_pick
ALEXANDRIA_AGENTS__SPLIT__MIN_CHILDREN=2
ALEXANDRIA_AGENTS__SPLIT__MAX_CHILDREN=5

# Logging configuration
ALEXANDRIA_LOGGING__LEVEL=INFO
ALEXANDRIA_LOGGING__JSON_OUTPUT=false
ALEXANDRIA_LOGGING__FILE_HANDLER_ENABLED=true
ALEXANDRIA_LOGGING__FILE_PATH_PATTERN=<REDACTED>
ALEXANDRIA_LOGGING__STREAM_HANDLER_ENABLED=true
ALEXANDRIA_LOGGING__STREAM_FORMAT=[%(asctime)s] %(levelname)-8s %(message)s
ALEXANDRIA_LOGGING__STREAM_DATE_FORMAT=%H:%M:%S

# Postgres configuration
ALEXANDRIA_DATABASE__HOST=localhost
ALEXANDRIA_DATABASE__PORT=5432
ALEXANDRIA_DATABASE__USER=alexandria
ALEXANDRIA_DATABASE__PASSWORD=<REDACTED>
ALEXANDRIA_DATABASE__DATABASE=alexandria
ALEXANDRIA_DATABASE__SSL_MODE=<REDACTED>

# Queue configuration
ALEXANDRIA_QUEUE__ENABLED=true
ALEXANDRIA_QUEUE__MAX_ATTEMPTS=5
ALEXANDRIA_QUEUE__BATCH_SIZE=25

# Ingest configuration
ALEXANDRIA_INGEST__MAX_LEAF_DOCS=100

# Embedding configuration
ALEXANDRIA_EMBEDDING__PROVIDER=openai
ALEXANDRIA_EMBEDDING__BASE_URL=https://api.openai.com/v1
ALEXANDRIA_EMBEDDING__API_KEY=<REDACTED>
ALEXANDRIA_EMBEDDING__MODEL=text-embedding-3-small
# ALEXANDRIA_EMBEDDING__DIMENSIONS=1536
ALEXANDRIA_EMBEDDING__TIMEOUT_SECONDS=30.0

# Summarizer configuration
ALEXANDRIA_SUMMARIZER__PROVIDER=openai
ALEXANDRIA_SUMMARIZER__BASE_URL=https://api.openai.com/v1
ALEXANDRIA_SUMMARIZER__MODEL=gpt-4o-mini
ALEXANDRIA_SUMMARIZER__TIMEOUT_SECONDS=30.0
ALEXANDRIA_SUMMARIZER__API_KEY=<REDACTED>
